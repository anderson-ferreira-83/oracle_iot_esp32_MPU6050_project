# Python (cache regenerado automaticamente — nao commitar)
__pycache__/
*.pyc
*.pyo
.venv*/

# IDE (configuracoes locais de editor)
.idea/

# OS
.DS_Store
Thumbs.db

# Runtime logs e logs datados (gerados em execucao — nao commitar)
logs/*.log
logs/ml_transitions_2[0-9]*.json
logs/ml_transitions_current.txt

# Windows shortcuts
*.lnk

# Jupyter checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# NOTA: Repositorio PRIVADO.
# device_config.json, wifi_profiles.json, .env.oracle e .vscode/
# sao commitados intencionalmente para facilitar transferencia entre maquinas.
